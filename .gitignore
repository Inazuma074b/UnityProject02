# ----------------------------------------------------------------------
# Unity 完整版 .gitignore (整合優化設定)
# ----------------------------------------------------------------------

# --- Unity 官方標準忽略目錄 ---
.utmp/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
*.log

# --- 素材相關 ---
*.blend1
*.blend1.meta
/[Mm]emoryCaptures/
/[Rr]ecordings/

# --- IDE 與編譯相關設定 ---
.vs/
.gradle/
*.csproj
*.unityproj
*.sln
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.DotSettings.user
.consulo/
ExportedObj/

# --- Meta 檔案與報告 ---
*.pidb.meta
*.pdb.meta
*.mdb.meta
sysinfo.txt
mono_crash.*

# --- 建置檔案 ---
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# --- 其他系統與工具 ---
crashlytics-build.properties
InitTestScene*.unity*
Thumbs.db
Desktop.ini
.DS_Store

# --- Addressables 與 Visual Scripting ---
/ServerData
/[Aa]ssets/StreamingAssets/aa*
/[Aa]ssets/AddressableAssetsData/link.xml*
/[Aa]ssets/Addressables_Temp*
/[Aa]ssets/AddressableAssetsData/*/*.bin*
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db*
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers*
/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# --- 個人化優化區 (根據需求調整) ---
# 排除 Shader 快取
/[Aa]ssets/Artifacts/
/[Aa]ssets/ShaderCache/

# 排除 AI 工具或腳本產生的暫存
.gemini/
gemini_chat_history.json
*.sln.docstates
[Bb]in/
[Oo]bj/